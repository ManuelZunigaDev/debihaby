{
    "1": {
        "title": "¿Qué es un Activo?",
        "category": "Activos",
        "steps": {
            "explicacion": { "type": "theory", "content": "Un Activo es un recurso controlado por la empresa que generará beneficios futuros. Es todo lo que la empresa TIENE o le DEBEN." },
            "evaluacion": { "type": "drag_drop", "content": "Arrastra los Activos al cofre.", "items": [{"text": "Efectivo", "type": "activo"}, {"text": "Deuda Bancaria", "type": "pasivo"}, {"text": "Mercancía", "type": "activo"}] }
        }
    },
    "2": {
        "title": "Activo Circulante",
        "category": "Activos",
        "steps": {
            "explicacion": { "type": "theory", "content": "Son los bienes que se pueden convertir en efectivo en menos de un año. Incluye Caja, Bancos, Clientes e Inventarios." },
            "evaluacion": { "type": "drag_drop", "content": "Identifica los circulantes.", "items": [{"text": "Dinero en Caja", "type": "activo"}, {"text": "Edificio", "type": "pasivo"}] }
        }
    },
    "3": {
        "title": "Activo Fijo",
        "category": "Activos",
        "steps": {
            "explicacion": { "type": "theory", "content": "Bienes duraderos para operar la empresa, no para la venta. Terrenos, Edificios, Mobiliario." },
            "evaluacion": { "type": "drag_drop", "content": "Busca los activos fijos.", "items": [{"text": "Camión de reparto", "type": "activo"}, {"text": "Papelería", "type": "pasivo"}] }
        }
    },
    "4": {
        "title": "Activo Diferido",
        "category": "Activos",
        "steps": {
            "explicacion": { "type": "theory", "content": "Pagos hechos por adelantado, como Rentas o Seguros pagados por anticipado." },
            "evaluacion": { "type": "drag_drop", "content": "Selecciona el diferido.", "items": [{"text": "Seguro Pagado por Anticipado", "type": "activo"}, {"text": "Factura por Pagar", "type": "pasivo"}] }
        }
    },
    "5": {
        "title": "¿Qué es un Pasivo?",
        "category": "Pasivos",
        "steps": {
            "explicacion": { "type": "theory", "content": "Las obligaciones y deudas del negocio con terceros (fuentes externas)." },
            "evaluacion": { "type": "drag_drop", "content": "Arrastra las deudas.", "items": [{"text": "Préstamo Bancario", "type": "activo"}, {"text": "Venta Realizada", "type": "pasivo"}] }
        }
    },
    "6": {
        "title": "Pasivo a Corto Plazo",
        "category": "Pasivos",
        "steps": {
            "explicacion": { "type": "theory", "content": "Deudas que deben pagarse en un periodo menor a un año, como Proveedores o impuestos." },
            "evaluacion": { "type": "drag_drop", "content": "Busca deudas cercanas.", "items": [{"text": "Pago a Proveedor (30 días)", "type": "activo"}, {"text": "Hipoteca (10 años)", "type": "pasivo"}] }
        }
    },
    "7": {
        "title": "Pasivo a Largo Plazo",
        "category": "Pasivos",
        "steps": {
            "explicacion": { "type": "theory", "content": "Obligaciones con vencimiento mayor a un año, como Hipotecas o créditos bancarios grandes." },
            "evaluacion": { "type": "drag_drop", "content": "Identifica el largo plazo.", "items": [{"text": "Crédito Hipotecario", "type": "activo"}, {"text": "Luz por pagar", "type": "pasivo"}] }
        }
    },
    "8": {
        "title": "El Capital Contable",
        "category": "Capital",
        "steps": {
            "explicacion": { "type": "theory", "content": "Es el valor residual de los activos una vez deducidos los pasivos. Lo que realmente pertenece a los dueños." },
            "evaluacion": { "type": "drag_drop", "content": "Busca el patrimonio.", "items": [{"text": "Utilidad neta", "type": "activo"}, {"text": "Cuentas por pagar", "type": "pasivo"}] }
        }
    },
    "9": {
        "title": "Capital Social",
        "category": "Capital",
        "steps": {
            "explicacion": { "type": "theory", "content": "Son las aportaciones iniciales y adicionales hechas por los socios o dueños de la empresa." },
            "evaluacion": { "type": "drag_drop", "content": "Arrastra las aportaciones.", "items": [{"text": "Aportación de socios", "type": "activo"}, {"text": "Gasto de luz", "type": "pasivo"}] }
        }
    },
    "10": {
        "title": "La Ecuación Contable",
        "category": "General",
        "steps": {
            "explicacion": { "type": "theory", "content": "El equilibrio fundamental: Activo = Pasivo + Capital. Todo lo que tienes vino de una deuda o de tu dinero." },
            "evaluacion": { "type": "drag_drop", "content": "¿Sigue el equilibrio?", "items": [{"text": "Activo = Pasivo + Capital", "type": "activo"}, {"text": "Activo = Pasivo - Capital", "type": "pasivo"}] }
        }
    },
    "11": {
        "title": "Partida Doble",
        "category": "General",
        "steps": {
            "explicacion": { "type": "theory", "content": "A todo cargo corresponde un abono. Cada transacción afecta al menos dos cuentas para mantener el equilibrio." },
            "evaluacion": { "type": "drag_drop", "content": "Aplica la partida doble.", "items": [{"text": "Un cargo y un abono", "type": "activo"}, {"text": "Solo un cargo", "type": "pasivo"}] }
        }
    },
    "12": {
        "title": "Ingresos y Gastos",
        "category": "Estados Financieros",
        "steps": {
            "explicacion": { "type": "theory", "content": "Los ingresos son entradas por ventas; los gastos son salidas necesarias para operar. La resta es la utilidad." },
            "evaluacion": { "type": "drag_drop", "content": "Busca la ganancia.", "items": [{"text": "Venta de servicios", "type": "activo"}, {"text": "Pago de nómina", "type": "pasivo"}] }
        }
    },
    "13": {
        "title": "El Balance General",
        "category": "Estados Financieros",
        "steps": {
            "explicacion": { "type": "theory", "content": "Estado financiero que muestra Activos, Pasivos y Capital a una fecha determinada. Es una foto de la empresa." },
            "evaluacion": { "type": "drag_drop", "content": "Arma el balance.", "items": [{"text": "Activos y Pasivos", "type": "activo"}, {"text": "Solo gastos", "type": "pasivo"}] }
        }
    },
    "14": {
        "title": "Estado de Resultados",
        "category": "Estados Financieros",
        "steps": {
            "explicacion": { "type": "theory", "content": "Reporte que muestra si la empresa ganó o perdió dinero en un periodo, restando gastos a los ingresos." },
            "evaluacion": { "type": "drag_drop", "content": "Analiza resultados.", "items": [{"text": "Ingresos - Gastos", "type": "activo"}, {"text": "Activo + Pasivo", "type": "pasivo"}] }
        }
    },
    "15": {
        "title": "Cierre Contable",
        "category": "General",
        "steps": {
            "explicacion": { "type": "theory", "content": "Proceso final del ciclo donde se cancelan cuentas temporales y se determina el resultado final para iniciar un nuevo año." },
            "evaluacion": { "type": "drag_drop", "content": "Finaliza el ciclo.", "items": [{"text": "Cancelar saldos", "type": "activo"}, {"text": "Comprar camión", "type": "pasivo"}] }
        }
    }
}